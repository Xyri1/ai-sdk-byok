SUPABASE_URL=
SUPABASE_SECRET_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_BASE_URL=
BYOK_EXAMPLE_LOG_LEVEL=info

# Optional: Upstash-compatible Redis REST cache for server-side credential records.
# Disabled unless both URL and token are set. Values stored in this cache include
# plaintext API keys, so the Redis project is trusted secret infrastructure.
BYOK_REDIS_REST_URL=
BYOK_REDIS_REST_TOKEN=
BYOK_CREDENTIAL_CACHE_TTL_SECONDS=60
