# Any reachable Postgres works: Neon, a local install, or Docker, e.g.
#   docker run --name byok-postgres -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:17
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Generate with: openssl rand -base64 32
AI_SDK_BYOK_MASTER_KEY=

BYOK_EXAMPLE_LOG_LEVEL=info

# Optional Redis REST credential cache (leave empty to disable)
BYOK_REDIS_REST_URL=
BYOK_REDIS_REST_TOKEN=
BYOK_CREDENTIAL_CACHE_TTL_SECONDS=60
