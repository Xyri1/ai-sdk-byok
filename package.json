{
  "name": "ai-sdk-byok",
  "version": "0.0.0",
  "description": "Bring-your-own-key credential storage helpers for AI SDK applications.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./supabase": {
      "types": "./dist/supabase/index.d.ts",
      "import": "./dist/supabase/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "supabase/migrations",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@supabase/supabase-js": "^2.49.4",
    "@types/node": "^22.15.19",
    "eslint": "^9.27.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  }
}
